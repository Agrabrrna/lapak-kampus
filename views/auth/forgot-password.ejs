<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lupa Password - KampusLapak</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    
    <!-- Dark mode toggle top right -->
    <div class="position-absolute top-0 end-0 p-4">
        <button class="btn btn-link theme-toggle-btn text-muted p-2" title="Toggle Dark Mode">
            <i class="fas fa-moon fs-5"></i>
        </button>
    </div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5 col-xl-4">
                <div class="card border-0 shadow p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                            <i class="fas fa-key fs-3"></i>
                        </div>
                        <h4 class="fw-bold text-dark">Lupa Password?</h4>
                        <p class="text-muted small">Jangan khawatir! Masukkan email Anda di bawah dan kami akan mengirimkan instruksi pemulihan.</p>
                    </div>

                    <form action="#" method="POST">
                        <div class="form-floating mb-4 position-relative">
                            <i class="fas fa-envelope position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="z-index: 5;"></i>
                            <input type="email" class="form-control ps-5" id="email" placeholder="name@mahasiswa.ac.id" required>
                            <label for="email" class="text-muted ps-5">Email Mahasiswa</label>
                        </div>

                        <button type="button" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow mb-3" onclick="alert('Ini adalah halaman placeholder. Fitur reset password sedang dalam pengembangan!')">
                            Kirim Link Pemulihan
                        </button>
                        
                        <div class="text-center mt-4">
                            <a href="/auth/login" class="text-muted small text-decoration-none"><i class="fas fa-arrow-left me-1"></i> Kembali ke Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="/js/theme-toggle.js"></script>
</body>
</html>
