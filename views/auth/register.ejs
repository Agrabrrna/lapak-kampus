<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }
    </style>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card p-4">
                    <div class="text-center mb-4">
                        <h2 class="text-primary fw-bold">KampusLapak</h2>
                        <p class="text-muted">Buat akun untuk memulai transaksi</p>
                    </div>

                    <% if (error) { %>
                        <div class="alert alert-danger" role="alert">
                            <%= error %>
                        </div>
                    <% } %>

                    <form action="/auth/register" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        
                        <div class="mb-3">
                            <label for="name" class="form-label">Nama Lengkap</label>
                            <input type="text" class="form-control" id="name" name="name" required placeholder="Masukkan nama lengkap">
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" name="email" required placeholder="name@mahasiswa.ac.id">
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required placeholder="Password minimal 6 karakter">
                        </div>

                        <div class="mb-3">
                            <label for="role" class="form-label">Daftar Sebagai</label>
                            <select class="form-select" id="role" name="role">
                                <option value="PEMBELI" selected>Pembeli (Cari & beli kebutuhan kuliah)</option>
                                <option value="PENJUAL">Penjual (Mulai menjual barang Anda)</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="phone" class="form-label">Nomor Telepon (Opsional)</label>
                            <input type="text" class="form-control" id="phone" name="phone" placeholder="0812xxxxxx">
                        </div>

                        <div class="mb-3">
                            <label for="address" class="form-label">Alamat Lengkap (Opsional)</label>
                            <textarea class="form-control" id="address" name="address" rows="2" placeholder="Alamat kos / rumah"></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2">Daftar Akun</button>
                    </form>

                    <div class="text-center mt-3">
                        <p class="mb-0 text-muted">Sudah punya akun? <a href="/auth/login" class="text-primary fw-bold text-decoration-none">Masuk</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
