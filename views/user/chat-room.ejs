<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/products">KampusLapak</a>
            
            <div class="ms-auto d-flex align-items-center">
                <button class="btn btn-link nav-link theme-toggle-btn p-2 me-3" title="Toggle Dark Mode">
                    <i class="fas fa-moon fs-5 text-muted"></i>
                </button>
                <a href="/chat/inbox" class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold">Kembali ke Kotak Masuk</a>
            </div>
        </div>
    </nav>

    <!-- Content -->
    <div class="container mt-4 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <!-- Product Header if exists -->
                <% if (product) { %>
                    <div class="card p-3 mb-3 border-0 shadow-sm">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-muted small">Membahas produk:</span>
                                <h6 class="fw-bold mb-0 text-dark"><%= product.name %></h6>
                                <p class="text-danger small fw-bold mb-0">Rp <%= parseFloat(product.price).toLocaleString('id-ID') %></p>
                            </div>
                            <a href="/products/<%= product.id %>" class="btn btn-outline-primary btn-sm rounded-pill fw-bold">Lihat Detail</a>
                        </div>
                    </div>
                <% } %>

                <!-- Chat Card -->
                <div class="card shadow border-0">
                    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center">
                        <div class="bg-primary text-white p-2 rounded-circle me-3 d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;">
                            <i class="fas fa-user"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-0"><%= otherUser.name %></h5>
                            <span class="badge bg-light text-muted border small"><%= otherUser.role %></span>
                        </div>
                    </div>
                    
                    <div class="card-body p-0">
                        <!-- Messages Container -->
                        <div class="chat-box d-flex flex-column m-3" id="chatBox">
                            <% messages.forEach(msg => { %>
                                <% const isMe = msg.senderId === user.id; %>
                                <div class="msg-bubble <%= isMe ? 'msg-outgoing' : 'msg-incoming' %>">
                                    <p class="mb-1 fw-medium" style="line-height: 1.4;"><%= msg.message %></p>
                                    <small class="d-block text-end chat-time mt-1" style="font-size: 0.7rem; font-weight: 500;">
                                        <%= new Date(msg.createdAt).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                                    </small>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- Chat Input Form -->
                    <div class="card-footer bg-white border-top py-3">
                        <form id="chatForm" class="d-flex gap-2">
                            <input type="hidden" name="_csrf" id="csrfToken" value="<%= csrfToken %>">
                            <input type="text" id="messageInput" name="message" class="form-control rounded-pill px-4" placeholder="Ketik pesan Anda di sini..." required autocomplete="off">
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Polling & Send Logic script -->
    <script>
        const chatBox = document.getElementById('chatBox');
        const chatForm = document.getElementById('chatForm');
        const messageInput = document.getElementById('messageInput');
        const csrfToken = document.getElementById('csrfToken').value;

        const otherUserId = '<%= otherUser.id %>';
        const productId = '<%= product ? product.id : "no-product" %>';
        const myId = '<%= user.id %>';

        // Auto scroll to bottom
        const scrollToBottom = () => {
            chatBox.scrollTop = chatBox.scrollHeight;
        };
        scrollToBottom();

        // Send message handler using Fetch (AJAX)
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const message = messageInput.value.trim();
            if (!message) return;

            messageInput.value = '';

            try {
                const response = await fetch(`/chat/send/${otherUserId}/${productId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        _csrf: csrfToken,
                        message: message
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    appendMessage(data.chat);
                    scrollToBottom();
                } else {
                    console.error('Failed to send message.');
                }
            } catch (err) {
                console.error('Network error while sending message:', err);
            }
        });

        // Helper to append a single message
        const appendMessage = (chat) => {
            const isMe = chat.senderId === myId;
            const bubble = document.createElement('div');
            bubble.className = `msg-bubble ${isMe ? 'msg-outgoing' : 'msg-incoming'}`;
            
            const time = new Date(chat.createdAt).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            
            bubble.innerHTML = `
                <p class="mb-1 fw-medium" style="line-height: 1.4;">${escapeHtml(chat.message)}</p>
                <small class="d-block text-end chat-time mt-1" style="font-size: 0.7rem; font-weight: 500;">${time}</small>
            `;
            chatBox.appendChild(bubble);
        };

        const escapeHtml = (text) => {
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        };

        // Polling loop to fetch new messages
        let messageCount = <%= messages.length %>;

        const pollMessages = async () => {
            try {
                const response = await fetch(`/api/chat/messages/${otherUserId}/${productId}`);
                if (response.ok) {
                    const data = await response.json();
                    if (data.messages.length > messageCount) {
                        chatBox.innerHTML = '';
                        data.messages.forEach(msg => appendMessage(msg));
                        messageCount = data.messages.length;
                        scrollToBottom();
                    }
                }
            } catch (err) {
                console.error('Error polling messages:', err);
            }
        };

        setInterval(pollMessages, 3000);
    </script>
    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="/js/theme-toggle.js"></script>
</body>
</html>
