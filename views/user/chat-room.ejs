<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <style>
        .chat-box {
            height: 400px;
            overflow-y: auto;
            background-color: #f8f9fa;
            border-radius: 8px;
            padding: 15px;
            border: 1px solid #dee2e6;
        }
        .msg-bubble {
            max-width: 70%;
            padding: 10px 15px;
            border-radius: 15px;
            margin-bottom: 10px;
            position: relative;
        }
        .msg-incoming {
            background-color: #ffffff;
            align-self: flex-start;
            border-bottom-left-radius: 2px;
            border: 1px solid #e9ecef;
        }
        .msg-outgoing {
            background-color: #0d6efd;
            color: #ffffff;
            align-self: flex-end;
            border-bottom-right-radius: 2px;
        }
    </style>
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/products">KampusLapak</a>
            <a href="/chat/inbox" class="btn btn-outline-light btn-sm">Kembali ke Kotak Masuk</a>
        </div>
    </nav>

    <!-- Content -->
    <div class="container mt-4 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <!-- Product Header if exists -->
                <% if (product) { %>
                    <div class="card p-3 mb-3 border-0 shadow-sm">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-muted small">Membahas produk:</span>
                                <h6 class="fw-bold mb-0 text-dark"><%= product.name %></h6>
                                <p class="text-danger small fw-bold mb-0">Rp <%= parseFloat(product.price).toLocaleString('id-ID') %></p>
                            </div>
                            <a href="/products/<%= product.id %>" class="btn btn-outline-primary btn-sm">Lihat Detail Produk</a>
                        </div>
                    </div>
                <% } %>

                <!-- Chat Card -->
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center">
                        <div class="bg-light p-2 rounded-circle me-3">
                            <span>👤</span>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-0"><%= otherUser.name %></h5>
                            <span class="badge bg-secondary small"><%= otherUser.role %></span>
                        </div>
                    </div>
                    
                    <div class="card-body">
                        <!-- Messages Container -->
                        <div class="chat-box d-flex flex-column" id="chatBox">
                            <% messages.forEach(msg => { %>
                                <% const isMe = msg.senderId === user.id; %>
                                <div class="msg-bubble <%= isMe ? 'msg-outgoing' : 'msg-incoming' %>">
                                    <p class="mb-1"><%= msg.message %></p>
                                    <small class="d-block text-end <%= isMe ? 'text-white-50' : 'text-muted' %>" style="font-size: 0.75rem;">
                                        <%= new Date(msg.createdAt).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                                    </small>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- Chat Input Form -->
                    <div class="card-footer bg-white border-top py-3">
                        <form id="chatForm" class="d-flex gap-2">
                            <input type="hidden" name="_csrf" id="csrfToken" value="<%= csrfToken %>">
                            <input type="text" id="messageInput" name="message" class="form-control" placeholder="Tulis pesan Anda..." required autocomplete="off">
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Kirim</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Polling & Send Logic script -->
    <script>
        const chatBox = document.getElementById('chatBox');
        const chatForm = document.getElementById('chatForm');
        const messageInput = document.getElementById('messageInput');
        const csrfToken = document.getElementById('csrfToken').value;

        const otherUserId = '<%= otherUser.id %>';
        const productId = '<%= product ? product.id : "no-product" %>';
        const myId = '<%= user.id %>';

        // Auto scroll to bottom
        const scrollToBottom = () => {
            chatBox.scrollTop = chatBox.scrollHeight;
        };
        scrollToBottom();

        // Send message handler using Fetch (AJAX)
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const message = messageInput.value.trim();
            if (!message) return;

            messageInput.value = '';

            try {
                const response = await fetch(`/chat/send/${otherUserId}/${productId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        _csrf: csrfToken,
                        message: message
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    // Append sent message immediately
                    appendMessage(data.chat);
                    scrollToBottom();
                } else {
                    console.error('Failed to send message.');
                }
            } catch (err) {
                console.error('Network error while sending message:', err);
            }
        });

        // Helper to append a single message
        const appendMessage = (chat) => {
            const isMe = chat.senderId === myId;
            const bubble = document.createElement('div');
            bubble.className = `msg-bubble ${isMe ? 'msg-outgoing' : 'msg-incoming'}`;
            
            const time = new Date(chat.createdAt).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            
            bubble.innerHTML = `
                <p class="mb-1">${escapeHtml(chat.message)}</p>
                <small class="d-block text-end ${isMe ? 'text-white-50' : 'text-muted'}" style="font-size: 0.75rem;">${time}</small>
            `;
            chatBox.appendChild(bubble);
        };

        const escapeHtml = (text) => {
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        };

        // Polling loop to fetch new messages
        let messageCount = <%= messages.length %>;

        const pollMessages = async () => {
            try {
                const response = await fetch(`/api/chat/messages/${otherUserId}/${productId}`);
                if (response.ok) {
                    const data = await response.json();
                    if (data.messages.length > messageCount) {
                        // Clear and redraw chat box to ensure ordering
                        chatBox.innerHTML = '';
                        data.messages.forEach(msg => appendMessage(msg));
                        messageCount = data.messages.length;
                        scrollToBottom();
                    }
                }
            } catch (err) {
                console.error('Error polling messages:', err);
            }
        };

        // Poll every 3 seconds
        setInterval(pollMessages, 3000);
    </script>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
