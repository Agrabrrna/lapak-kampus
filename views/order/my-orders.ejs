<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <style>
        .status-badge {
            font-size: 0.85rem;
            padding: 0.4em 0.8em;
        }
    </style>
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/user/dashboard">KampusLapak</a>
            <a href="/user/dashboard" class="btn btn-outline-light btn-sm">Kembali ke Dashboard</a>
        </div>
    </nav>

    <div class="container mt-5">
        <h2 class="fw-bold mb-4">📦 Pesanan Saya</h2>

        <% if (messages.success_msg) { %>
            <div class="alert alert-success"><%= messages.success_msg %></div>
        <% } %>
        <% if (messages.error_msg) { %>
            <div class="alert alert-danger"><%= messages.error_msg %></div>
        <% } %>

        <% if (orders.length === 0) { %>
            <div class="card p-5 text-center border-0 shadow-sm">
                <h4 class="text-muted">Anda belum memiliki pesanan.</h4>
                <a href="/products" class="btn btn-primary mt-3 w-25 mx-auto">Mulai Belanja</a>
            </div>
        <% } else { %>
            <% orders.forEach(order => { %>
                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-muted small">ID Pesanan: <%= order.id %></span>
                            <h6 class="mb-0 fw-bold mt-1">Penjual: <%= order.seller.name %></h6>
                        </div>
                        <div>
                            <% if (order.status === 'PENDING') { %>
                                <span class="badge bg-warning text-dark status-badge">Menunggu Diproses</span>
                            <% } else if (order.status === 'DIPROSES') { %>
                                <span class="badge bg-info text-dark status-badge">Sedang Diproses</span>
                            <% } else if (order.status === 'SELESAI') { %>
                                <span class="badge bg-success status-badge">Selesai</span>
                            <% } else if (order.status === 'DIBATALKAN') { %>
                                <span class="badge bg-danger status-badge">Dibatalkan</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="card-body">
                        <% order.orderDetails.forEach(detail => { %>
                            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                <div>
                                    <h6 class="mb-0">
                                        <a href="/products/<%= detail.productId %>" class="text-dark text-decoration-none"><%= detail.product.name %></a>
                                    </h6>
                                    <small class="text-muted"><%= detail.quantity %> x Rp <%= parseFloat(detail.price).toLocaleString('id-ID') %></small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold">Rp <%= parseFloat(detail.subtotal).toLocaleString('id-ID') %></div>
                                    <% if (order.status === 'SELESAI') { %>
                                        <a href="/products/<%= detail.productId %>" class="btn btn-sm btn-outline-primary mt-1">⭐ Beri Ulasan</a>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                        
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <h5 class="fw-bold mb-0">Total: Rp <%= parseFloat(order.totalPrice).toLocaleString('id-ID') %></h5>
                            
                            <!-- Action Buttons based on status -->
                            <div class="d-flex gap-2">
                                <% if (order.status === 'PENDING') { %>
                                    <form action="/orders/<%= order.id %>/status" method="POST" onsubmit="return confirm('Yakin ingin membatalkan pesanan ini?');">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="newStatus" value="DIBATALKAN">
                                        <button type="submit" class="btn btn-outline-danger btn-sm fw-bold">Batalkan Pesanan</button>
                                    </form>
                                <% } %>
                                <% if (order.status === 'DIPROSES') { %>
                                    <form action="/orders/<%= order.id %>/status" method="POST">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="newStatus" value="SELESAI">
                                        <button type="submit" class="btn btn-success btn-sm fw-bold">Pesanan Diterima</button>
                                    </form>
                                <% } %>
                                <a href="https://wa.me/<%= order.seller.phone ? order.seller.phone.replace(/[^0-9]/g, '') : '' %>" target="_blank" class="btn btn-outline-success btn-sm fw-bold">Hubungi Penjual</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</body>
</html>
