<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <style>
        .detail-img {
            max-height: 450px;
            object-fit: contain;
            width: 100%;
            background-color: #f8f9fa;
            border-radius: 12px;
        }
        .thumbnail-img {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 8px;
            cursor: pointer;
            border: 2px solid transparent;
        }
        .thumbnail-img.active {
            border-color: #0d6efd;
        }
    </style>
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/products">KampusLapak</a>
            <a href="/products" class="btn btn-outline-light btn-sm">Kembali ke Katalog</a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-5 mb-5">
        <div class="row">
            <!-- Product Images -->
            <div class="col-md-6 mb-4">
                <% 
                    const primaryImg = product.images.find(img => img.isPrimary) || product.images[0];
                    const imgPath = primaryImg ? primaryImg.imagePath : 'https://placehold.co/600x400?text=No+Image';
                %>
                <img src="<%= imgPath %>" id="mainImage" class="detail-img img-fluid shadow-sm mb-3" alt="<%= product.name %>">
                
                <% if (product.images && product.images.length > 1) { %>
                    <div class="d-flex gap-2 flex-wrap">
                        <% product.images.forEach((img, idx) => { %>
                            <img src="<%= img.imagePath %>" class="thumbnail-img <%= img.isPrimary || (idx === 0 && !product.images.some(i => i.isPrimary)) ? 'active' : '' %>" onclick="changeImage(this, '<%= img.imagePath %>')" alt="Thumbnail">
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <!-- Product Details & Seller Info -->
            <div class="col-md-6">
                <div class="card p-4 border-0 shadow-sm mb-4">
                    <span class="badge bg-primary align-self-start mb-2"><%= product.category.name %></span>
                    <h1 class="fw-bold text-dark h2 mb-1"><%= product.name %></h1>
                    <span class="badge bg-<%= product.condition === 'BARU' ? 'success' : 'warning' %> align-self-start mb-3"><%= product.condition %></span>
                    
                    <h3 class="text-danger fw-bold mb-3">Rp <%= parseFloat(product.price).toLocaleString('id-ID') %></h3>
                    <p class="text-muted">Stok: <strong><%= product.stock %></strong> | Kondisi: <strong><%= product.condition %></strong></p>
                    
                    <hr>
                    
                    <h5 class="fw-bold text-dark">Deskripsi Produk</h5>
                    <p class="text-secondary" style="white-space: pre-line;"><%= product.description %></p>
                    
                    <hr>

                    <!-- Cart and Wishlist Actions -->
                    <% if (user) { %>
                        <% if (user.role === 'PEMBELI') { %>
                            
                            <!-- Add to Cart Form -->
                            <form action="/cart/add/<%= product.id %>" method="POST" class="mb-3">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <div class="d-flex gap-2">
                                    <input type="number" name="quantity" class="form-control w-25" value="1" min="1" max="<%= product.stock %>" required>
                                    <button type="submit" class="btn btn-primary flex-grow-1 fw-bold">🛒 Tambah ke Keranjang</button>
                                </div>
                            </form>

                            <!-- Wishlist Form -->
                            <% if (inWishlist) { %>
                                <form action="/wishlist/delete-by-product/<%= product.id %>" method="POST">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="btn btn-danger w-100 py-2 fw-bold">❤️ Hapus dari Wishlist</button>
                                </form>
                            <% } else { %>
                                <form action="/wishlist/add/<%= product.id %>" method="POST">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="btn btn-outline-primary w-100 py-2 fw-bold">🤍 Simpan ke Wishlist</button>
                                </form>
                            <% } %>
                        <% } else { %>
                            <button class="btn btn-outline-secondary w-100 py-2 fw-bold" disabled>Hanya Pembeli yang Bisa Membeli</button>
                        <% } %>
                    <% } else { %>
                        <div class="d-flex flex-column gap-2">
                            <a href="/auth/login" class="btn btn-primary w-100 py-2 fw-bold">🛒 Tambah ke Keranjang (Perlu Login)</a>
                            <a href="/auth/login" class="btn btn-outline-primary w-100 py-2 fw-bold">🤍 Simpan ke Wishlist (Perlu Login)</a>
                        </div>
                    <% } %>
                </div>

                <!-- Seller Info -->
                <div class="card p-4 border-0 shadow-sm">
                    <h5 class="fw-bold text-primary mb-3">Informasi Penjual</h5>
                    <div class="d-flex align-items-center">
                        <div class="bg-light p-3 rounded-circle me-3">
                            <span class="fs-4">👤</span>
                        </div>
                        <div>
                            <h6 class="fw-bold text-dark mb-0"><%= product.user.name %></h6>
                            <p class="text-muted small mb-0">Mahasiswa Penjual</p>
                        </div>
                    </div>
                    <div class="mt-3">
                        <p class="small text-muted mb-1">Email: <strong><%= product.user.email %></strong></p>
                        <p class="small text-muted mb-2">Telepon/WA: <strong><%= product.user.phone || 'Tidak dicantumkan' %></strong></p>
                        
                        <% if (user) { %>
                            <% if (user.id !== product.userId) { %>
                                <a href="/chat/initiate/<%= product.id %>" class="btn btn-primary btn-sm w-100 mt-2 fw-bold">💬 Hubungi via Chat Internal</a>
                            <% } %>
                            <a href="https://wa.me/<%= product.user.phone ? product.user.phone.replace(/[^0-9]/g, '') : '' %>" target="_blank" class="btn btn-success btn-sm w-100 mt-2 fw-bold">🟢 Hubungi via WhatsApp</a>
                        <% } else { %>
                            <a href="/auth/login" class="btn btn-primary btn-sm w-100 mt-2 fw-bold">Login untuk Hubungi Penjual</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function changeImage(element, path) {
            document.getElementById('mainImage').src = path;
            const thumbnails = document.querySelectorAll('.thumbnail-img');
            thumbnails.forEach(thumb => thumb.classList.remove('active'));
            element.classList.add('active');
        }
    </script>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
