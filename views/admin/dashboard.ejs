<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <!-- Navbar -->
    <%- include('../partials/navbar') %>

    <div class="container mt-4">
        <h2 class="fw-bold mb-4">Dashboard Statistik</h2>
        
        <% if (messages && messages.error_msg) { %>
            <div class="alert alert-danger"><%= messages.error_msg %></div>
        <% } %>
        <% if (messages && messages.success_msg) { %>
            <div class="alert alert-success"><%= messages.success_msg %></div>
        <% } %>

        <div class="row">
            <div class="col-md-4">
                <a href="/admin/users" class="text-decoration-none">
                    <div class="card text-white bg-primary mb-3 shadow-sm border-0" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-users"></i> Total Pengguna</h5>
                            <h2 class="fw-bold"><%= totalUsers %></h2>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/admin/orders" class="text-decoration-none">
                    <div class="card text-white bg-success mb-3 shadow-sm border-0" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-shopping-cart"></i> Total Pesanan</h5>
                            <h2 class="fw-bold"><%= totalOrders %></h2>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/admin/categories" class="text-decoration-none">
                    <div class="card text-white bg-warning mb-3 shadow-sm border-0" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-tags"></i> Total Kategori</h5>
                            <h2 class="fw-bold"><%= totalCategories %></h2>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <h3 class="fw-bold mb-3 mt-4">Akses Fitur Penjualan</h3>
        <div class="row">
            <div class="col-md-6 mb-3">
                <a href="/seller/products" class="btn btn-outline-primary w-100 py-3 shadow-sm fw-bold d-flex align-items-center justify-content-center gap-2">
                    <i class="fas fa-box-open fs-5"></i> Kelola Produk Saya
                </a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/orders/incoming" class="btn btn-outline-success w-100 py-3 shadow-sm fw-bold d-flex align-items-center justify-content-center gap-2">
                    <i class="fas fa-inbox fs-5"></i> Pesanan Masuk (Toko Saya)
                </a>
            </div>
        </div>
    </div>
    <script src="/js/bootstrap.bundle.min.js"></script>

    <script src="/js/theme-toggle.js"></script>
</body>
</html>
